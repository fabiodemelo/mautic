{% extends '@MauticCore/Default/content.html.twig' %}

{% block headerTitle %}{{ 'mautic.syncdata.dashboard.title'|trans }}{% endblock %}

{% block actions %}
    <div class="btn-group ml-5">
        <button id="sd-sync-btn" class="btn btn-default" onclick="SyncData.runSync()">
            <i class="ri-refresh-line"></i> {{ 'mautic.syncdata.dashboard.run_sync'|trans }}
        </button>
    </div>
{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ asset('plugins/MauticSyncDataBundle/Assets/css/syncdata.css') }}?v={{ "now"|date("YmdHi") }}">

<div class="sd-dashboard">
    {# Summary Cards (5-column CSS grid) #}
    <div class="sd-cards-grid">

        {# 1. Fetched from SendGrid (last run) #}
        <div class="sd-card sd-card-purple" title="Records returned by the SendGrid suppression API on the most recent successful sync. Cumulative across all runs: {{ stats.fetched_total|default(0)|number_format }}.">
            <div class="sd-card-icon"><i class="ri-cloud-line"></i></div>
            <div class="sd-card-body">
                <div class="sd-card-value" id="sd-fetched">{{ stats.fetched_last|default(0)|number_format }}</div>
                <div class="sd-card-label">Last Sync from SendGrid</div>
            </div>
        </div>

        {# 2. Stored in Mautic #}
        <div class="sd-card sd-card-primary" title="Suppression records stored in this plugin's database. May be lower than 'Fetched' until all records are processed.">
            <div class="sd-card-icon"><i class="ri-database-2-line"></i></div>
            <div class="sd-card-body">
                <div class="sd-card-value" id="sd-total">{{ stats.total_synced|number_format }}</div>
                <div class="sd-card-label">Stored in Mautic</div>
                <div class="sd-card-sub">
                    <span class="sd-tag sd-tag-danger">{{ stats.by_action.dnc|default(0)|number_format }} DNC</span>
                    <span class="sd-tag sd-tag-info">{{ stats.by_action.segment|default(0)|number_format }} Segment</span>
                    <span class="sd-tag sd-tag-muted">{{ stats.by_action.unmatched|default(0)|number_format }} Unmatched</span>
                </div>
            </div>
        </div>

        {# 3. New (24h / 7d / 30d toggle) #}
        <div class="sd-card sd-card-info" title="Suppression records added to this plugin's database in the selected time window.">
            <div class="sd-card-icon"><i class="ri-add-circle-line"></i></div>
            <div class="sd-card-body">
                <div class="sd-card-value" id="sd-new">{{ stats.new_24h|number_format }}</div>
                <div class="sd-card-label">
                    <span class="sd-period-toggle">
                        <a href="#" class="sd-period active" data-period="24h">24h</a> |
                        <a href="#" class="sd-period" data-period="7d">7d</a> |
                        <a href="#" class="sd-period" data-period="30d">30d</a>
                    </span>
                </div>
            </div>
        </div>

        {# 4. Contacts Protected #}
        <div class="sd-card sd-card-success" title="Unique Mautic contacts that were either added to the Do Not Contact list or moved to a designated segment by this plugin. These contacts will no longer receive emails from Mautic.">
            <div class="sd-card-icon"><i class="ri-user-shield-line"></i></div>
            <div class="sd-card-body">
                <div class="sd-card-value" id="sd-protected">{{ stats.contacts_protected|number_format }}</div>
                <div class="sd-card-label">Contacts Protected <i class="ri-information-line sd-card-help"></i></div>
            </div>
        </div>

        {# 5. Last Sync #}
        <div class="sd-card sd-card-{% if stats.last_sync.status == 'success' %}success{% elseif stats.last_sync.status == 'failed' %}danger{% else %}default{% endif %}" title="Timestamp of the most recent successful sync run.">
            <div class="sd-card-icon"><i class="ri-time-line"></i></div>
            <div class="sd-card-body">
                <div class="sd-card-value sd-card-value-date" id="sd-lastsync">
                    {% if stats.last_sync.time %}
                        {{ stats.last_sync.time }}
                    {% else %}
                        {{ 'mautic.syncdata.dashboard.never'|trans }}
                    {% endif %}
                </div>
                <div class="sd-card-label">{{ 'mautic.syncdata.dashboard.last_sync'|trans }}</div>
            </div>
        </div>

    </div>

    {# Charts Row #}
    <div class="row mt-lg">
        <div class="col-md-5">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">{{ 'mautic.syncdata.dashboard.breakdown'|trans }}</h3>
                </div>
                <div class="panel-body">
                    <div class="sd-chart-container">
                        <canvas id="sd-breakdown-chart"></canvas>
                    </div>
                    {% if stats.total_synced == 0 %}
                        <div class="sd-empty-state">
                            <p>{{ 'mautic.syncdata.dashboard.no_data'|trans }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        {{ 'mautic.syncdata.dashboard.trends'|trans }}
                        <div class="pull-right sd-chart-filters">
                            <select id="sd-trend-period" class="form-control input-sm" style="display:inline-block;width:auto;">
                                <option value="7d">{{ 'mautic.syncdata.filter.period.7d'|trans }}</option>
                                <option value="30d" selected>{{ 'mautic.syncdata.filter.period.30d'|trans }}</option>
                                <option value="90d">{{ 'mautic.syncdata.filter.period.90d'|trans }}</option>
                            </select>
                            <select id="sd-trend-type" class="form-control input-sm" style="display:inline-block;width:auto;">
                                <option value="">{{ 'mautic.syncdata.filter.all_types'|trans }}</option>
                                {% for type in types %}
                                    <option value="{{ type }}">{{ ('mautic.syncdata.type.' ~ type)|trans }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </h3>
                </div>
                <div class="panel-body">
                    <div class="sd-chart-container sd-chart-wide">
                        <canvas id="sd-trend-chart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Recent Suppressions Table #}
    <div class="row mt-lg">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        {{ 'mautic.syncdata.dashboard.recent'|trans }}
                        <div class="pull-right">
                            <input type="text" id="sd-search-email" class="form-control input-sm" placeholder="{{ 'mautic.syncdata.filter.search'|trans }}" style="display:inline-block;width:200px;">
                            <select id="sd-filter-type" class="form-control input-sm" style="display:inline-block;width:auto;">
                                <option value="">{{ 'mautic.syncdata.filter.all_types'|trans }}</option>
                                {% for type in types %}
                                    <option value="{{ type }}">{{ ('mautic.syncdata.type.' ~ type)|trans }}</option>
                                {% endfor %}
                            </select>
                            <a href="{{ path('mautic_syncdata_dashboard_export') }}" class="btn btn-sm btn-default">
                                <i class="ri-download-line"></i> {{ 'mautic.syncdata.dashboard.export_csv'|trans }}
                            </a>
                        </div>
                    </h3>
                </div>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="sd-suppressions-table">
                            <thead>
                                <tr>
                                    <th>{{ 'mautic.syncdata.table.email'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.type'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.reason'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.source_date'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.synced_date'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.action'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody id="sd-suppressions-body">
                                {% for item in recent.items %}
                                <tr>
                                    <td>
                                        {% if item.contact_id %}
                                            <a href="{{ path('mautic_contact_action', {objectAction: 'view', objectId: item.contact_id}) }}">{{ item.email }}</a>
                                        {% else %}
                                            {{ item.email }}
                                        {% endif %}
                                    </td>
                                    <td><span class="label sd-type-{{ item.type }}">{{ item.type_label }}</span></td>
                                    <td class="sd-reason-cell" title="{{ item.reason }}">{{ (item.reason|default('-'))|slice(0, 60) }}{% if item.reason|default('')|length > 60 %}…{% endif %}</td>
                                    <td>{{ item.source_date }}</td>
                                    <td>{{ item.synced_date }}</td>
                                    <td><span class="label label-{{ item.action == 'dnc' ? 'danger' : (item.action == 'segment' ? 'info' : 'default') }}">{{ item.action|upper }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <div id="sd-suppressions-pagination" class="text-center">
                        {% if recent.pages > 1 %}
                            <nav>
                                <ul class="pagination pagination-sm">
                                    {% for p in 1..recent.pages %}
                                        <li class="{{ p == recent.page ? 'active' : '' }}">
                                            <a href="#" onclick="SyncData.loadSuppressions({{ p }}); return false;">{{ p }}</a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </nav>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Sync History Table #}
    <div class="row mt-lg">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">{{ 'mautic.syncdata.dashboard.sync_history'|trans }}</h3>
                </div>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table class="table table-striped" id="sd-history-table">
                            <thead>
                                <tr>
                                    <th>{{ 'mautic.syncdata.table.status'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.type'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.started'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.duration'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.fetched'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.added'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.skipped'|trans }}</th>
                                    <th>{{ 'mautic.syncdata.table.unmatched'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody id="sd-history-body">
                                {% for log in history.items %}
                                <tr>
                                    <td>
                                        <span class="label label-{{ log.status == 'success' ? 'success' : (log.status == 'failed' ? 'danger' : (log.status == 'running' ? 'warning' : 'default')) }}">
                                            {{ log.status|upper }}
                                        </span>
                                    </td>
                                    <td>{{ log.sync_type }}</td>
                                    <td>{{ log.started_at }}</td>
                                    <td>{{ log.duration ? log.duration ~ 's' : '-' }}</td>
                                    <td>{{ log.fetched }}</td>
                                    <td>{{ log.added }}</td>
                                    <td>{{ log.skipped }}</td>
                                    <td>{{ log.unmatched }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var sgsBreakdownData = {{ breakdown|json_encode|raw }};
    var sgsTrendData     = {{ trend|json_encode|raw }};
    var sgsStats         = {{ stats|json_encode|raw }};
</script>
<script src="{{ asset('plugins/MauticSyncDataBundle/Assets/js/dashboard.js') }}?v={{ "now"|date("YmdHi") }}"></script>
{% endblock %}
