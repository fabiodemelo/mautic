{
    "name": "mauticplugin/syncdata-bundle",
    "description": "Sync suppressions (bounces, spam reports, blocks, invalid emails, unsubscribes) to Mautic DNC or segments.",
    "type": "mautic-plugin",
    "version": "2.1.0",
    "keywords": ["mautic", "syncdata", "suppression", "dnc", "bounce", "email"],
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Fabio de Melo",
            "email": "support@demelos.com",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "support@demelos.com",
        "issues": "https://github.com/fabiodemelo/mautic/issues",
        "source": "https://github.com/fabiodemelo/mautic"
    },
    "require": {
        "php": ">=8.1",
        "mautic/core-lib": ">=5.0"
    },
    "autoload": {
        "psr-4": {
            "MauticPlugin\\MauticSyncDataBundle\\": ""
        }
    },
    "extra": {
        "install-directory-name": "MauticSyncDataBundle"
    }
}
