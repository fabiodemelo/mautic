{% extends '@MauticCore/Default/content.html.twig' %}

{% block headerTitle %}{{ 'mautic.syncdata.settings.title'|trans }}{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ asset('plugins/MauticSyncDataBundle/Assets/css/syncdata.css') }}">

<div class="sd-settings">
    <form id="sd-settings-form" method="POST" action="{{ path('mautic_syncdata_settings_save') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('syncdata_settings') }}">

        {# API Connection #}
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="ri-key-line"></i> API Connection</h3>
            </div>
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="control-label" for="sd-api-key">{{ 'mautic.syncdata.settings.api_key'|trans }}</label>
                            <div class="input-group">
                                <input type="password" id="sd-api-key" name="api_key" class="form-control"
                                       placeholder="{{ hasApiKey ? '••••••••••••••••' : 'SG.xxxxxxxxxx' }}"
                                       autocomplete="off">
                                <span class="input-group-btn">
                                    <button type="button" class="btn btn-default" id="sd-test-btn" onclick="testConnection()">
                                        <i class="ri-link"></i> {{ 'mautic.syncdata.settings.test_connection'|trans }}
                                    </button>
                                </span>
                            </div>
                            <p class="help-block">{{ 'mautic.syncdata.settings.api_key.help'|trans }}</p>
                            <div id="sd-test-result" style="margin-top: 10px;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Suppression Types #}
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="ri-list-check-2"></i> {{ 'mautic.syncdata.settings.enabled_types'|trans }}</h3>
            </div>
            <div class="panel-body">
                <div class="row">
                    {% for type in types %}
                    <div class="col-md-4">
                        <div class="sd-type-config">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" name="enabled_types[]" value="{{ type }}"
                                           {{ type in (settings.enabled_types|default(types)) ? 'checked' : '' }}>
                                    {{ ('mautic.syncdata.type.' ~ type)|trans }}
                                </label>
                            </div>
                            <div class="form-group form-group-sm" style="margin-left: 20px;">
                                <label class="control-label">{{ 'mautic.syncdata.settings.action_mode'|trans }}</label>
                                <select name="action_modes[{{ type }}]" class="form-control input-sm sd-action-mode" data-type="{{ type }}">
                                    <option value="dnc" {{ (settings.action_modes[type]|default('dnc')) == 'dnc' ? 'selected' : '' }}>
                                        {{ 'mautic.syncdata.settings.action_dnc'|trans }}
                                    </option>
                                    <option value="segment" {{ (settings.action_modes[type]|default('')) == 'segment' ? 'selected' : '' }}>
                                        {{ 'mautic.syncdata.settings.action_segment'|trans }}
                                    </option>
                                </select>
                                <select name="target_segments[{{ type }}]" class="form-control input-sm sd-segment-select mt-sm"
                                        data-type="{{ type }}"
                                        style="{{ (settings.action_modes[type]|default('dnc')) == 'segment' ? '' : 'display:none;' }}">
                                    <option value="">-- {{ 'mautic.syncdata.settings.target_segment'|trans }} --</option>
                                    {% for segId, segName in segments %}
                                        <option value="{{ segId }}" {{ (settings.target_segments[type]|default('')) == segId ? 'selected' : '' }}>
                                            {{ segName }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Sync Settings #}
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="ri-settings-3-line"></i> Sync Settings</h3>
            </div>
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">{{ 'mautic.syncdata.settings.sync_interval'|trans }}</label>
                            <select name="sync_interval" class="form-control">
                                {% for val, label in intervalChoices %}
                                    <option value="{{ val }}" {{ (settings.sync_interval|default(15)) == val ? 'selected' : '' }}>{{ label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">{{ 'mautic.syncdata.settings.initial_range'|trans }}</label>
                            <select name="initial_sync_range" class="form-control">
                                {% for val, label in rangeChoices %}
                                    <option value="{{ val }}" {{ (settings.initial_sync_range|default(30)) == val ? 'selected' : '' }}>{{ label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">{{ 'mautic.syncdata.settings.notification_email'|trans }}</label>
                            <input type="email" name="notification_email" class="form-control"
                                   value="{{ settings.notification_email|default('') }}"
                                   placeholder="admin@example.com">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">{{ 'mautic.syncdata.settings.spike_threshold'|trans }}</label>
                            <input type="number" name="spike_threshold" class="form-control"
                                   value="{{ settings.spike_threshold|default(50) }}" min="1">
                            <p class="help-block">{{ 'mautic.syncdata.settings.spike_threshold.help'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Save Button #}
        <div class="row">
            <div class="col-md-12">
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line"></i> Save Settings
                </button>
                <a href="{{ path('mautic_syncdata_dashboard') }}" class="btn btn-default">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>

<script>
function testConnection() {
    var btn = document.getElementById('sd-test-btn');
    var resultDiv = document.getElementById('sd-test-result');
    var apiKey = document.getElementById('sd-api-key').value;

    btn.disabled = true;
    btn.innerHTML = '<i class="ri-loader-4-line ri-spin"></i> Testing...';
    resultDiv.innerHTML = '';

    var formData = new FormData();
    formData.append('api_key', apiKey);

    fetch('{{ path("mautic_syncdata_settings_test") }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': mauticAjaxCsrf },
        body: formData
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
        btn.disabled = false;
        btn.innerHTML = '<i class="ri-link"></i> Test Connection';
        if (data.success) {
            resultDiv.innerHTML = '<div class="alert alert-success"><i class="ri-check-line"></i> Connected to SendGrid (' + (data.account || '') + ')</div>';
        } else {
            resultDiv.innerHTML = '<div class="alert alert-danger"><i class="ri-error-warning-line"></i> ' + (data.error || 'Connection failed') + '</div>';
        }
    })
    .catch(function () {
        btn.disabled = false;
        btn.innerHTML = '<i class="ri-link"></i> Test Connection';
        resultDiv.innerHTML = '<div class="alert alert-danger">Request failed</div>';
    });
}

// Toggle segment selector visibility based on action mode
document.querySelectorAll('.sd-action-mode').forEach(function (select) {
    select.addEventListener('change', function () {
        var type = this.dataset.type;
        var segSelect = document.querySelector('.sd-segment-select[data-type="' + type + '"]');
        if (segSelect) {
            segSelect.style.display = this.value === 'segment' ? '' : 'none';
        }
    });
});
</script>
{% endblock %}
